{
  "name": "fmctl",
  "version": "0.0.0",
  "private": true,
  "description": "Manage YAML frontmatter across folders of inter-linked Markdown files",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    }
  },
  "bin": {
    "fmctl": "./dist/cli/main.js"
