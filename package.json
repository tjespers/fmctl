    "commander": "^15.0.0",
    "ignore": "^7.0.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
