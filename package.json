{
  "name": "@tjespers/fmctl",
  "version": "0.1.0",
  "description": "Manage YAML frontmatter across folders of inter-linked Markdown files",
  "keywords": [
    "frontmatter",
    "yaml",
    "markdown",
    "cli",
    "yaml-frontmatter",
    "markdown-metadata",
    "json-schema",
    "frontmatter-cli"
  ],
  "homepage": "https://github.com/tjespers/fmctl#readme",
  "bugs": {
    "url": "https://github.com/tjespers/fmctl/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tjespers/fmctl.git"
  },
  "license": "Apache-2.0",
  "author": "Tim Jespers",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    }
  },
  "bin": {
    "fmctl": "./dist/cli/main.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^15.0.0",
    "ignore": "^7.0.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
